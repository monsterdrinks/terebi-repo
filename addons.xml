<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="plugin.video.terebi" name="Terebi" version="1.0.0" provider-name="Antigravity">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests" version="2.25.1"/>
    <import addon="script.module.beautifulsoup4" version="4.9.3"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="main.py">
    <provides>video executable</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en">Terebi Live Channels</summary>
    <description lang="en">Custom Kodi Add-on to scrape and play 24/7 channels.</description>
    <platform>all</platform>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>
</addon>

<addon id="repository.terebi" name="Terebi Repository" version="1.0.0" provider-name="Antigravity">
    <extension point="xbmc.addon.repository" name="Terebi Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/monsterdrinks/terebi-repo/main/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/monsterdrinks/terebi-repo/main/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/monsterdrinks/terebi-repo/main/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Terebi Repository</summary>
        <description>Download and install updates for the Terebi addon.</description>
        <platform>all</platform>
    </extension>
</addon>

</addons>
