<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.terebi" name="Terebi" version="1.0.0" provider-name="Antigravity">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests" version="2.25.1"/>
    <import addon="script.module.beautifulsoup4" version="4.9.3"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="main.py">
    <provides>video executable</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en">Terebi Live Channels</summary>
    <description lang="en">Custom Kodi Add-on to scrape and play 24/7 channels.</description>
    <platform>all</platform>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>
</addon>
